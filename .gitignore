# Oracle proprietary libraries (extracted from database pod)
*.jar
*.so
*.so.*

# Build directory (generated by download script)
build/

# OCI native libraries (extracted from Oracle pod)
oci-libs/
oci-libs-temp/
*.tar.gz

# Temporary files
*.tmp
*.log

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Claude directory
.claude/

# Exclude all markdown files except README.md
*.md
!README.md

# Exclude all check/diagnose/find/test/verify/troubleshoot scripts
check-*.sh
diagnose-*.sh
find-*.sh
test-*.sh
verify-*.sh
troubleshoot-*.sh

# Exclude other non-deployment scripts
apply-xstreams-config.sh
create-registry-secret.sh
extract-oci-selective.sh
setup-tnsnames.sh
update-dockerfile-for-oci.sh

# Exclude non-deployment YAML files
gemini-code-*.yaml
oracle-deployment.yaml
oracle-pvc.yaml
oracle-service.yaml
kafkaconnector-inventory-connector-oracle-xs.yaml
